# --- App ---
ENV=dev
DEBUG=true

# --- Database ---
DATABASE_URL=mysql+aiomysql://root:bharath@localhost:3306/synthetic_ai_user
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=bharath
DB_NAME=synthetic_ai_user

# --- Auth ---
JWT_SECRET_KEY=change-me-in-prod

# --- LLM Gateway ---
# Leave GEMINI_API_KEY unset to run fully offline via synthetic (Faker) fallback.
GEMINI_API_KEY=
GEMINI_MODEL=gemini/gemini-1.5-flash

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=ollama/llama3.1

# --- Redis (Milestone 2+) ---
REDIS_URL=redis://localhost:6379/0