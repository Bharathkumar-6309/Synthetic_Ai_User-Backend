# --- App ---
ENV=dev
DEBUG=true

# --- Database (defaults to local SQLite, zero setup needed) ---
DATABASE_URL=sqlite+aiosqlite:///./vidzai.db
# For Postgres/Neon:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/vidzai

# --- Auth ---
JWT_SECRET_KEY=change-me-in-prod

# --- LLM Gateway ---
# Provider order: Groq -> Gemini -> Ollama -> synthetic (Faker) fallback.
# Leave all keys unset to run fully offline via the synthetic fallback.
GROQ_API_KEY=
GROQ_MODEL=groq/llama-3.3-70b-versatile

GEMINI_API_KEY=
GEMINI_MODEL=gemini/gemini-1.5-flash

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=ollama/llama3.1

# --- Redis (Milestone 2+) ---
REDIS_URL=redis://localhost:6379/0
